# Copy this file to docker/.env and fill in your values.
# Never commit the actual .env file.

# ── Required ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Generation (choose one provider) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GENERATION_PROVIDER=anthropic
GENERATION_MODEL=claude-sonnet-3-7

# ── Reranking ─────────────────────────────────────────────────────────────────
COHERE_API_KEY=...

# ── Observability ─────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Databases (override defaults only if not using docker-compose) ─────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
POSTGRES_URL=postgresql+asyncpg://rag:rag@postgres:5432/rag

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_KEYS=your-api-key-1,your-api-key-2
RATE_LIMIT_PER_MINUTE=60

# ── Model / retrieval defaults (optional overrides) ───────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
METADATA_EXTRACTION_MODEL=gpt-4o-mini
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
CONFIDENCE_THRESHOLD=0.45
MAX_CONTEXT_CHARS=6000
CHUNK_SIZE_WORDS=200
CHUNK_OVERLAP_WORDS=30
