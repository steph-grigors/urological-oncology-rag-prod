# ════════════════════════════════════════════════════════════════════════════════
# Urological Oncology RAG — Environment Configuration
# ════════════════════════════════════════════════════════════════════════════════
#
# 1. Copy this file:   cp docker/.env.example docker/.env
# 2. Fill in secrets   (never commit docker/.env to git)
# 3. Start services:   docker-compose --env-file docker/.env up
#
# Defaults shown are suitable for the docker-compose stack.
# Change only the values marked "REQUIRED" before starting.
# ════════════════════════════════════════════════════════════════════════════════

# ── LLM API Keys (REQUIRED) ────────────────────────────────────────────────────
#
# OpenAI: used for embeddings (text-embedding-3-small) and optional generation.
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic: primary generation model (claude-sonnet-4-6 by default).
# Get a key at: https://console.anthropic.com/
# Leave empty to fall back to OpenAI generation.
ANTHROPIC_API_KEY=sk-ant-...

# ── Generation provider ────────────────────────────────────────────────────────
#
# Which provider to use for answer generation.
# Values: anthropic | openai
GENERATION_PROVIDER=anthropic

# Model name for generation.  Use the full model ID.
# Anthropic examples: claude-sonnet-4-6, claude-haiku-4-5-20251001
# OpenAI examples:    gpt-4o, gpt-4o-mini
GENERATION_MODEL=claude-sonnet-4-6

# ── Reranking (optional but recommended) ──────────────────────────────────────
#
# Cohere cross-encoder reranker.  Leave empty to skip reranking (slightly lower
# retrieval quality but no Cohere account required).
# Get a key at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# ── Application security ───────────────────────────────────────────────────────
#
# Comma-separated list of API keys accepted by the /query endpoint.
# Example: API_KEYS=user-key-abc,user-key-xyz
# In development with APP_ENV=development and no keys set, auth is bypassed.
API_KEYS=your-api-key-here

# Separate admin key for privileged operations (POST /eval/run).
# If empty, falls back to API_KEYS validation.
ADMIN_API_KEY=your-admin-key-here

# ── Application environment ────────────────────────────────────────────────────
#
# Values: development | staging | production
# development — auth bypass when API_KEYS is empty; /docs available
# production  — strict auth; /docs hidden
APP_ENV=development

# Log verbosity.  Values: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Max requests per minute per IP address (0 = disabled).
RATE_LIMIT_PER_MINUTE=60

# ── Vector store — Qdrant ─────────────────────────────────────────────────────
#
# Internal Docker hostname when using docker-compose; localhost for local dev.
QDRANT_URL=http://qdrant:6333

# Leave empty for no auth (default Qdrant Community has no auth).
QDRANT_API_KEY=

# Collection name — must match what was used during ingestion.
QDRANT_COLLECTION=urological_oncology_papers

# ── Document store — PostgreSQL ───────────────────────────────────────────────
#
# asyncpg driver URL.  Change host from 'postgres' to 'localhost' for local dev.
POSTGRES_URL=postgresql+asyncpg://rag:rag@postgres:5432/rag

# ── Observability — Langfuse (optional) ──────────────────────────────────────
#
# Langfuse traces every query end-to-end for latency and quality monitoring.
# Self-hosted: start with --profile langfuse then set LANGFUSE_HOST below.
# Cloud: sign up at https://langfuse.com and use the cloud keys.
# Leave all three empty to disable tracing.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Used only when running the langfuse profile in docker-compose.
LANGFUSE_NEXTAUTH_SECRET=changeme-in-production
LANGFUSE_SALT=changeme-in-production

# ── Model defaults (optional overrides) ───────────────────────────────────────
#
# Embedding model — must be 1536-dim to match the Qdrant collection schema.
EMBEDDING_MODEL=text-embedding-3-small

# Model used for study-design metadata extraction during ingestion.
METADATA_EXTRACTION_MODEL=gpt-4o-mini

# ── Retrieval parameters ──────────────────────────────────────────────────────
#
# Number of candidates retrieved before reranking (dense + sparse).
# Higher = better recall, higher latency.
TOP_K_RETRIEVAL=20

# Number of chunks returned to the generation layer after reranking.
TOP_K_RERANK=5

# Minimum reranker confidence to produce a non-refused answer.
# Range [0, 1].  0.45 is the production-tuned default.
CONFIDENCE_THRESHOLD=0.45

# Maximum combined length of context chunks passed to the LLM (characters).
MAX_CONTEXT_CHARS=6000

# ── Chunking parameters (used during ingestion) ────────────────────────────────
CHUNK_SIZE_WORDS=200
CHUNK_OVERLAP_WORDS=30

# ── Streamlit UI ──────────────────────────────────────────────────────────────
#
# URL of the FastAPI backend as seen by the Streamlit container.
# Docker internal: http://api:8000
# Local dev:       http://localhost:8000
API_BACKEND_URL=http://api:8000
